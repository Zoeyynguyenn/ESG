  "source_role_registry": {
    "version": "1.0.0",
    "description": "Source role semantics for aggregation sufficiency",
    "role_classes": {
      "required": "Must contribute numeric value when metric exists in corpus",
      "supporting": "May contribute numeric or context; not a sole blocker",
      "optional": "Context-only or aggregate summary; absent_by_design OK",
      "authoritative": "Single-source sufficient anchor when others absent"
    },
    "classification_rules": [
      {
        "role_class": "optional",
        "match_tokens": [
          "summary",
          "aggregate",
          "context",
          "narrative evidence"
        ]
      },
      {
        "role_class": "authoritative",
        "match_tokens": [
          "authoritative",
          "financial / enterprise metrics",
          "primary numeric table"
        ]
      },
      {
        "role_class": "supporting",
        "match_tokens": [
          "supporting",
          "secondary"
        ]
      }
    ],
    "default_role_class": "required",
    "sufficiency_rules": {
      "single_source_sufficient": {
        "requires": [
          "resolved_value",
          "authoritative_or_probe_source"
        ],
        "optional_roles_absent_ok": true
      },
      "multi_source_sufficient": {
        "requires": [
          "resolved_value",
          "roles_with_metric>=1"
        ]
      },
      "honest_abstain": {
        "requires": [
          "source_not_disclosed_or_coverage_gap"
        ]
      }
    },
    "synthesis_gate": {
      "allowed_readiness_states": [
        "single_source_sufficient",
        "multi_source_sufficient",
        "aggregation_ready"
      ],
      "min_quant_rate": 0.6,
      "qualitative_requires_synthesis": true
    }
  }
}
# LLM (auto = ollama -> openai_api -> extractive)
RAG_LLM_MODE=auto
OLLAMA_MODEL=qwen2.5:7b-instruct

# OpenAI — chi bat buoc cho RAGAS tren top configs (--enable-ragas, gioi han cau)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Jina Rerank API (https://jina.ai/reranker) — optional, for reranker_backend=jina_api
JINA_API_KEY=
JINA_RERANK_MODEL=jina-reranker-v3
# Jina tuning (tranh 429 token/min): prefilter 16 doc, 400 chars/doc, throttle 2s
RAG_JINA_RERANK_MAX_DOCS=16
RAG_JINA_MAX_CHARS=400
JINA_RERANK_MIN_INTERVAL_SEC=2
JINA_RERANK_MAX_RETRIES=3
RAG_RERANK_BLEND_ALPHA=0.40

# RAGAS cost control (model candidate / focused runs)
RAGAS_ENABLED=false
RAGAS_MAX_QUESTIONS=10

RAG_TOP_K=4
 
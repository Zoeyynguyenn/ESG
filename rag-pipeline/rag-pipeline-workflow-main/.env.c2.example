# C2 RunPod — copy to .env.c2 (không commit). Merge với .env khi chạy C2 benchmark.

# OpenAI embed (giữ BC11)
OPENAI_API_KEY=sk-...

# vLLM trên RunPod (OpenAI-compatible) — không thêm slash thừa trước /v1
C2_LLM_BASE_URL=https://<pod-id>-8000.proxy.runpod.net/v1
C2_LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

# Map sang biến repo — .env.c2 GHI ĐÈ .env (quan trọng: .env thường có OPENAI_MODEL=gpt-4o-mini)
OPENAI_BASE_URL=https://YOUR-POD-8000.proxy.runpod.net/v1
OPENAI_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

RAG_BENCHMARK_LLM_PROVIDER=openai_api
RAG_BENCHMARK_LANGUAGE=ko

# Reranker GPU (chạy trên host có CUDA — khuyến nghị cùng pod)
RAG_RERANK_ENABLED=true
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANK_STRICT=true

# Optional: RunPod SSH (ghi journal, không commit)
# RUNPOD_POD_ID=
# RUNPOD_SSH_HOST=

# Copy file nay thanh `.env` o thu muc repo (KHONG commit .env)
# Windows PowerShell:
#   Copy-Item .env.local.example .env
# Sau do dien OPENAI_API_KEY neu muon RAGAS tren top configs.

RAG_LLM_MODE=auto
OLLAMA_MODEL=qwen2.5:7b-instruct

# Chi dung cho RAGAS tren top 2-3 config sau metric noi bo (khong chay loop tat ca case)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

RAGAS_ENABLED=false
RAGAS_MAX_QUESTIONS=10

RAG_TOP_K=4
